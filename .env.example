# ============================================================
#  .env.example — 複製此檔為 .env 並填入實際值
#  指令：cp .env.example .env
# ============================================================

# ── 伺服器本機 IP（工廠內網）─────────────────────────────────
# 範例：192.168.1.100  請用 ipconfig 查詢實際 IP
SERVER_IP=192.168.1.100

# ── HuggingFace Token（下載 Qwen3.6 模型用）────────────────
# 從 https://huggingface.co/settings/tokens 取得（read 權限即可）
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── vLLM API Key（內部服務互相呼叫用，自行設定）────────────
VLLM_API_KEY=local-vllm-secret-key-change-this

# ── Dify 密鑰（隨機長字串，用於 session 加密）──────────────
DIFY_SECRET_KEY=change-this-to-a-random-64-char-string

# ── Dify 資料庫密碼 ──────────────────────────────────────────
DIFY_DB_PASSWORD=dify_db_password_change_this

# ── Redis 密碼 ───────────────────────────────────────────────
REDIS_PASSWORD=redis_password_change_this

# ── Open WebUI 密鑰 ──────────────────────────────────────────
WEBUI_SECRET_KEY=open_webui_secret_change_this

# ── Qdrant API Key（可選，留空則不啟用認證）────────────────
QDRANT_API_KEY=qdrant_api_key_change_this

# ── n8n 登入帳密 ────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=n8n_password_change_this
